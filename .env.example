# =============================================================================
# analista-bi — Modelo de credenciais e configuração
# =============================================================================
# Copie este arquivo para `.env` e preencha com seus valores reais.
# O arquivo `.env` está no .gitignore e NUNCA deve ser commitado.
#
#   cp .env.example .env
#
# =============================================================================

# -----------------------------------------------------------------------------
# Modo de autenticação
# -----------------------------------------------------------------------------
# Opções:
#   device_code       -> login interativo com sua conta corporativa (recomendado
#                        para uso individual do gestor). Não requer Client Secret.
#   service_principal -> autenticação automatizada (app registrado no Azure AD).
#                        Requer AZURE_CLIENT_SECRET e habilitações no tenant.
AUTH_MODE=device_code

# -----------------------------------------------------------------------------
# Credenciais do Azure AD
# -----------------------------------------------------------------------------
# Tenant ID (Diretório) do Azure AD — obrigatório nos dois modos.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# Client ID (ID do aplicativo).
#   - device_code: pode usar o app público padrão do Power BI, mas o ideal é
#     registrar um app próprio com permissões delegadas do Power BI.
#   - service_principal: ID do app registrado no Azure AD.
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Client Secret — OBRIGATÓRIO apenas quando AUTH_MODE=service_principal.
# Deixe em branco no modo device_code.
AZURE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Power BI — Workspace e Dataset padrão
# -----------------------------------------------------------------------------
# ID do workspace (grupo) do Power BI que contém o modelo semântico.
PBI_WORKSPACE_ID=00000000-0000-0000-0000-000000000000

# ID do dataset (modelo semântico) padrão para as consultas.
PBI_DATASET_ID=00000000-0000-0000-0000-000000000000

# -----------------------------------------------------------------------------
# Ajustes de operação (opcionais — há padrões conservadores)
# -----------------------------------------------------------------------------
# Limite local de requisições por minuto à API do Power BI.
PBI_RATE_LIMIT_PER_MIN=30

# Número máximo de tentativas em caso de erro transitório (429/5xx).
PBI_MAX_RETRIES=4

# Limite padrão de linhas retornadas por consulta (proteção de contexto).
PBI_DEFAULT_ROW_LIMIT=20

# Caminho do cache de token (device_code). Relativo à raiz do projeto.
TOKEN_CACHE_PATH=.token_cache.json
